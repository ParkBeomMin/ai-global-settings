{
  "mcpServers": {
    "gws": {
      "command": "npx",
      "args": [
        "-y",
        "gws-mcp-server",
        "--services",
        "drive,gmail,calendar"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp"
    },
    "firebase": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "experimental:mcp"]
    }
  }
}