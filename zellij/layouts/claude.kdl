layout {
    pane split_direction="vertical" {
        pane focus=true command="bash" {
            args "-c" "args=$(cat /tmp/claude-args 2>/dev/null); rm -f /tmp/claude-args; exec claude $args"
        }
        pane size=34 name="Dashboard" command="bash" {
            args "-c" "bash ~/.claude/panel-runner.sh"
        }
    }

    pane size=2 borderless=true {
        plugin location="zellij:status-bar"
    }
}
