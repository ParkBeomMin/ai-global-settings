layout {
    pane split_direction="vertical" {
        pane focus=true command="bash" {
            args "-c" "args=$(cat /tmp/claude-args 2>/dev/null); rm -f /tmp/claude-args; exec claude $args"
        }
        pane size="30%" name="Dashboard" {
            plugin location="file:~/.config/zellij/plugins/claude_dashboard.wasm" {
                claude_dir "/Users/bmpark/.claude"
                plan "max5"
            }
        }
    }

    pane size=2 borderless=true {
        plugin location="zellij:status-bar"
    }
}
