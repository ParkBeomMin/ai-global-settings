layout {
    pane split_direction="vertical" {
        pane focus=true command="bash" {
            args "-c" "args=$(cat /tmp/cursor-args 2>/dev/null); rm -f /tmp/cursor-args; exec agent $args"
        }
        pane size="30%" borderless=true command="bash" {
            args "-c" "bash ~/.cursor/panel-runner.sh"
        }
    }

    pane size=2 borderless=true {
        plugin location="zellij:status-bar"
    }
}
