{
  "permissions": {
    "allow": [
      "Bash(chmod +x ~/.claude/statusline-command.sh)",
      "WebFetch(domain:github.com)",
      "Bash(zellij --version)",
      "Bash(brew install:*)",
      "Bash(source ~/.zshrc)",
      "Bash(bash ~/.claude/panel.sh)",
      "Bash(chmod:*)",
      "Read(//tmp/**)",
      "Bash(ln -s ~/Workspace/ai-global-settings/scripts/claude-zellij.sh ~/.claude/claude-zellij.sh && ln -s ~/Workspace/ai-global-settings/scripts/cursor-zellij.sh ~/.cursor/cursor-zellij.sh && ls -la ~/.claude/claude-zellij.sh ~/.cursor/cursor-zellij.sh)",
      "Bash(echo $ZELLIJ_SESSION_NAME)"
    ]
  }
}
